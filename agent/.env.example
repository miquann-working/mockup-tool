# ── VPS Agent Configuration ──────────────────────────────────
# Copy this file to .env and fill in the values

# Port the agent listens on
AGENT_PORT=5001

# API key — paste from Admin Panel > VPS > secret_key
SECRET_KEY=paste-your-secret-key-here

# Main Server URL (no trailing slash)
SERVER_URL=http://192.168.1.100:4000

# Max simultaneous workers (= number of Gemini accounts on this VPS)
MAX_CONCURRENT=3

# Python executable (usually "python" on Windows)
PYTHON_BIN=python

# Run browser in headless mode (no GUI needed, for VMs without display)
# Set to 1 on headless servers, leave empty on machines with display
HEADLESS=

# Worker timeout in milliseconds (default: 15 minutes)
# WORKER_TIMEOUT_MS=900000
